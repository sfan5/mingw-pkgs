#!/bin/bash -eu

. ./common.sh
common_init "$@"

which nasm >/dev/null || which yasm >/dev/null || \
	{ echo >&2 "A standalone assembler is required for this build."; exit 1; }

pkgver=3.1.4.1
fetch_web "https://github.com/libjpeg-turbo/libjpeg-turbo/releases/download/${pkgver}/libjpeg-turbo-${pkgver}.tar.gz" \
	ecae8008e2cc9ade2f2c1bb9d5e6d4fb73e7c433866a056bd82980741571a022
unpack_tar "libjpeg-turbo-${pkgver}.tar.gz" --strip-components=1

cmake . "${CMAKE_FLAGS[@]}" -DCMAKE_INSTALL_PREFIX=/
make

common_flat_tree
make DESTDIR=$INSTALL_DIR install
rm -f $INSTALL_DIR/bin/*.exe
common_tidy

package $pkgver
