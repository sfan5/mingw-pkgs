#!/bin/bash -eu

. ./common.sh
common_init "$@"

pkgver=1.25.1
fetch_web "https://github.com/kcat/openal-soft/archive/refs/tags/$pkgver.tar.gz" \
	5f8efe8dfba5e9307a50251ba615ace857c7fa9dddfe34130b83e213d7f7cf24
unpack_tar "$pkgver.tar.gz" --strip-components=1

cmake . "${CMAKE_FLAGS[@]}" \
	-DALSOFT_EXAMPLES=OFF -DALSOFT_UTILS=OFF
make

common_flat_tree
make DESTDIR=$INSTALL_DIR install
rm -rf $INSTALL_DIR/share
common_tidy

package $pkgver
